{
  "format": "page",
  "id": "blog_home",
  "label": "Blog Home",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {}
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "placeholder": "",
          "allowTargetBlank": false,
          "single": "heading1"
        }
      },
      "caption": {
        "type": "StructuredText",
        "config": {
          "label": "Caption",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph"
        }
      },
      "pagination_title": {
        "type": "StructuredText",
        "config": {
          "label": "Pagination Title",
          "placeholder": "",
          "allowTargetBlank": false,
          "single": "heading2"
        }
      },
      "featured_blogs": {
        "type": "Group",
        "config": {
          "label": "Featured Blogs",
          "repeat": true,
          "fields": {
            "featured": {
              "type": "Link",
              "config": {
                "label": "Featured",
                "select": "document",
                "repeat": false,
                "customtypes": [
                  {
                    "id": "blog_page",
                    "fields": [
                      "title",
                      "snippet",
                      {
                        "id": "category",
                        "customtypes": [
                          {
                            "id": "category",
                            "fields": ["name"]
                          }
                        ]
                      },
                      "meta_image"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
