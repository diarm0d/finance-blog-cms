{
  "format": "page",
  "id": "blog_page",
  "label": "Blog Page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "article_body": {
              "type": "SharedSlice"
            },
            "article_header": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": ""
        }
      },
      "snippet": {
        "type": "Text",
        "config": {
          "label": "Snippet",
          "placeholder": ""
        }
      },
      "category": {
        "type": "Link",
        "config": {
          "label": "Category",
          "select": "document",
          "repeat": false,
          "customtypes": [
            {
              "id": "category",
              "fields": ["name"]
            }
          ]
        }
      },
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      },
      "follow": {
        "type": "Boolean",
        "config": {
          "label": "Follow",
          "placeholder_false": "false",
          "placeholder_true": "true",
          "default_value": true
        }
      },
      "index": {
        "type": "Boolean",
        "config": {
          "label": "index",
          "placeholder_false": "false",
          "placeholder_true": "true",
          "default_value": true
        }
      },
      "canonical": {
        "type": "Link",
        "config": {
          "label": "Canonical",
          "placeholder": "",
          "select": null,
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": false
        }
      },
      "structured_data": {
        "type": "Text",
        "config": {
          "label": "Structured Data",
          "placeholder": ""
        }
      },
      "author": {
        "type": "Link",
        "config": {
          "label": "Author",
          "select": "document",
          "repeat": false,
          "customtypes": [
            {
              "id": "author",
              "fields": ["name", "position", "avatar"]
            }
          ]
        }
      },
      "content_type": {
        "type": "Link",
        "config": {
          "label": "Content Type",
          "select": "document",
          "repeat": false,
          "customtypes": [
            {
              "id": "category",
              "fields": ["name"]
            }
          ]
        }
      }
    }
  }
}
