{
  "type": "SharedSlice",
  "id": "article_header",
  "name": "BlogHero",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "description": "Standard article header for editorial content.",
      "version": "initial",
      "imageUrl": "",
      "docURL": "...",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "",
            "allowTargetBlank": true,
            "single": "heading1"
          }
        },
        "header_image": {
          "type": "Image",
          "config": {
            "label": "Header Image"
          }
        },
        "author": {
          "type": "Link",
          "config": {
            "label": "author",
            "select": "document",
            "repeat": false,
            "customtypes": [
              {
                "id": "author",
                "fields": [
                  "name",
                  "avatar",
                  "position"
                ]
              }
            ]
          }
        },
        "published_date": {
          "type": "Date",
          "config": {
            "label": "Published Date"
          }
        },
        "reading_time": {
          "type": "Text",
          "config": {
            "label": "Reading Time"
          }
        },
        "blog_category": {
          "type": "Link",
          "config": {
            "label": "Blog Category",
            "select": "document",
            "repeat": false,
            "customtypes": [
              {
                "id": "category",
                "fields": [
                  "name"
                ]
              }
            ]
          }
        }
      },
      "items": {}
    }
  ]
}